#!/bin/bash
# =========================================================================
# PRE-FREEZE SKRIPT FUER VMWARE TOOLS (QUIESCING)
# Dieses Skript wird unmittelbar vor der Erstellung des VM-Snapshots
# ausgefuehrt. Es identifiziert die aktive Datenbank und versetzt diese
# in einen konsistenten Zustand.
# =========================================================================

set -e

# Protokollierung des Startzeitpunkts
echo "$(date): Pre-Freeze-Skript gestartet." >> /var/log/veeam-quiesce.log

# -------------------------------------------------------------------------
# 1. MARIADB / MYSQL
# -------------------------------------------------------------------------
if systemctl is-active --quiet mariadb || systemctl is-active --quiet mysql; then
    echo "$(date): MariaDB/MySQL erkannt. Tabellen werden gesperrt..." >> /var/log/veeam-quiesce.log

    # Erstellung einer Sperre im Hintergrund. Die Verbindung muss geoeffnet
    # bleiben, da die Sperre (READ LOCK) an die aktive Session gebunden ist.
    # Ein Sleep-Wert von 600 Sekunden dient als maximale Sicherheitsgrenze.
    # Es wird vorausgesetzt, dass die Authentifizierung fuer den root-Kontext
    # ueber das UNIX-Socket-Plugin oder eine lokale '.my.cnf'-Konfigurationsdatei
    # passwortlos konfiguriert ist.
    mysql -u root -e "FLUSH TABLES WITH READ LOCK; SELECT SLEEP(600);" &

    # Speicherung der Prozess-ID, um die Verbindung im Thaw-Skript zu beenden
    echo $! > /tmp/mysql_freeze.pid

    # Kurze Verzoegerung, um die Etablierung des Locks sicherzustellen
    sleep 2
fi

# -------------------------------------------------------------------------
# 2. POSTGRESQL
# -------------------------------------------------------------------------
if systemctl is-active --quiet postgresql; then
    echo "$(date): PostgreSQL erkannt. Checkpoint wird erzwungen..." >> /var/log/veeam-quiesce.log

    # Ein CHECKPOINT schreibt alle Dirty Pages aus dem Shared Buffer Pool
    # auf die Festplatte. Bei Storage-Snapshots (HPE BfSS) ist dies
    # ausreichend: PostgreSQL startet beim Restore automatisch in den
    # Recovery-Modus und spielt die WAL-Transaktionslogs bis zum
    # Snapshot-Zeitpunkt ein. Ein explizites pg_start_backup() ist bei
    # Storage-Snapshots nicht erforderlich, da der Snapshot
    # dateisystemkonsistent ist und PostgreSQL Crash Recovery beherrscht.
    sudo -u postgres psql -c "CHECKPOINT;" >> /var/log/veeam-quiesce.log 2>&1
fi

# -------------------------------------------------------------------------
# 3. MICROSOFT SQL SERVER (LINUX)
# -------------------------------------------------------------------------
if systemctl is-active --quiet mssql-server; then
    echo "$(date): MS SQL Server (Linux) erkannt. CHECKPOINT wird erzwungen..." >> /var/log/veeam-quiesce.log

    # MS SQL Server unter Linux registriert sich NICHT automatisch fuer
    # den fsfreeze-Mechanismus des Hypervisors (dies ist ein reiner
    # Windows-VSS-Mechanismus). Ein manueller CHECKPOINT stellt sicher,
    # dass alle Dirty Pages auf die Festplatte geschrieben werden.
    #
    # Das SA-Passwort wird aus einer geschuetzten Konfigurationsdatei
    # gelesen. Ist diese nicht vorhanden, wird das Skript mit einem
    # Hinweis abgebrochen.
    MSSQL_CONF="/etc/veeam/mssql_backup.conf"
    if [ -f "$MSSQL_CONF" ]; then
        MSSQL_PASSWORD=$(cat "$MSSQL_CONF")
        /opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P "$MSSQL_PASSWORD" -C -Q "CHECKPOINT;" >> /var/log/veeam-quiesce.log 2>&1
    else
        echo "$(date): FEHLER - Keine SA-Zugangsdaten unter $MSSQL_CONF. CHECKPOINT nicht moeglich." >> /var/log/veeam-quiesce.log
        exit 1
    fi
fi

exit 0